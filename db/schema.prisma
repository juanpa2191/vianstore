// VianStore — schema principal de Prisma.
//
// El schema `auth` lo gestiona Supabase Auth y Prisma NO lo migra.
// La app referencia `auth.users` por UUID desde `public.profile`; la FK se
// declara en el `migration.sql` inicial (raw SQL), no en Prisma, porque Prisma
// no puede crear FKs a modelos ignorados.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

// ---------------------------------------------------------------------------
// Roles y perfil de usuario (PR #2 / #3).
// ---------------------------------------------------------------------------

enum Role {
  admin
  customer

  @@schema("public")
}

/// Perfil de usuario de la app. `id` == `auth.users.id`.
/// Se crea automáticamente por trigger AFTER INSERT ON auth.users (ver migration.sql).
model Profile {
  id        String   @id @db.Uuid
  role      Role     @default(customer)
  fullName  String?  @map("full_name")
  phone     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("profile")
  @@schema("public")
}

// ---------------------------------------------------------------------------
// Catálogo (PR #4).
//
// Estructura: Product 1—N Variant 1—1 Sku. Variant = (color × size) por
// producto; Sku carga stock y precio. Se separa Sku de Variant para permitir
// mañana precios por canal / costo sin migrar la tabla principal.
//
// Precios en centavos (Int) para evitar aritmética decimal. UUID en todos los
// IDs de dominio para consistencia con auth.users.
// ---------------------------------------------------------------------------

enum ProductStatus {
  draft
  active
  archived

  @@schema("public")
}

model Brand {
  id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String    @unique
  slug     String    @unique
  products Product[]

  @@map("brand")
  @@schema("public")
}

model Color {
  id       String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String         @unique
  /// Hex sin `#`, ej "0f172a". Validación de formato en app + CHECK en DB.
  hex      String
  variants Variant[]
  images   ProductImage[]

  @@map("color")
  @@schema("public")
}

model Size {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Etiqueta imprimible (ej "38", "38.5", "M"). No parsear como número.
  label     String    @unique
  /// Orden estable para UI (35→42 asc).
  sortOrder Int       @map("sort_order")
  variants  Variant[]

  @@map("size")
  @@schema("public")
}

model Product {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String         @unique
  name        String
  description String?
  status      ProductStatus  @default(draft)
  brandId     String         @map("brand_id") @db.Uuid
  brand       Brand          @relation(fields: [brandId], references: [id], onDelete: Restrict)
  variants    Variant[]
  images      ProductImage[]
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([brandId])
  @@index([status])
  @@map("product")
  @@schema("public")
}

model Variant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorId   String   @map("color_id") @db.Uuid
  color     Color    @relation(fields: [colorId], references: [id], onDelete: Restrict)
  sizeId    String   @map("size_id") @db.Uuid
  size      Size     @relation(fields: [sizeId], references: [id], onDelete: Restrict)
  sku       Sku?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([productId, colorId, sizeId], name: "variant_product_color_size_uniq")
  @@index([productId])
  @@map("variant")
  @@schema("public")
}

model Sku {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId  String     @unique @map("variant_id") @db.Uuid
  variant    Variant    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  /// SKU imprimible/único para operaciones (ej "NIK-AF1-BLK-40").
  code       String     @unique
  /// Precio en centavos (COP no usa fracción, pero mantenemos el patrón).
  price      Int
  /// Stock disponible. No negativo — validación por CHECK en supplement.
  stock      Int        @default(0)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([price, stock])
  @@map("sku")
  @@schema("public")
}

// ---------------------------------------------------------------------------
// Direcciones y pedidos (PR #8).
//
// El MVP guarda **una** dirección por usuario (unique en `userId`). El scope
// del `CLAUDE.md` dice explícitamente "una guardada por usuario". El upsert de
// `/account/address` se apoya en ese unique.
//
// El pedido snapshotea:
//   - `addressSnapshot` (JSON): copia inmutable de la dirección al momento de
//     confirmar. Editar la dirección después NO cambia pedidos históricos.
//   - `OrderItem.unitPriceCents`: precio congelado por SKU. Si el admin sube
//     el precio, el pedido histórico mantiene el original.
//
// `OrderStatus` cubre el flujo manual sin pasarela: pedido queda `pendiente_pago`
// hasta que un admin lo mueva a `pagado` (PR #11).
// ---------------------------------------------------------------------------

enum OrderStatus {
  pendiente_pago
  pagado
  en_preparacion
  enviado
  entregado
  cancelado

  @@schema("public")
}

model Address {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @unique @map("user_id") @db.Uuid
  fullName   String   @map("full_name")
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String?  @map("postal_code")
  country    String   @default("CO")
  isDefault  Boolean  @default(true) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("address")
  @@schema("public")
}

model Order {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Nullable + ON DELETE SET NULL en auth.users: si el user se elimina, el
  /// pedido queda huérfano pero preservado. `userEmail` da trazabilidad para
  /// operaciones admin (soporte, refunds).
  userId           String?     @map("user_id") @db.Uuid
  userEmail        String      @map("user_email")
  /// Copia inmutable de la dirección al momento del pedido (JSON).
  addressSnapshot  Json        @map("address_snapshot")
  status           OrderStatus @default(pendiente_pago)
  subtotalCents    Int         @map("subtotal_cents")
  shippingCents    Int         @default(0) @map("shipping_cents")
  totalCents       Int         @map("total_cents")
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  items            OrderItem[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("order")
  @@schema("public")
}

model OrderItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId        String   @map("order_id") @db.Uuid
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  /// Restrict: los SKUs no pueden borrarse mientras existan OrderItems.
  skuId          String   @map("sku_id") @db.Uuid
  sku            Sku      @relation(fields: [skuId], references: [id], onDelete: Restrict)
  qty            Int
  /// Precio congelado por unidad al momento del pedido (centavos).
  unitPriceCents Int      @map("unit_price_cents")
  /// Redundante con qty * unitPriceCents; lo persistimos para simplificar
  /// reportes y evitar recomputaciones.
  subtotalCents  Int      @map("subtotal_cents")
  /// Copia del SKU code al momento del pedido (defensa contra renames en admin).
  skuCode        String   @map("sku_code")
  /// Copia del nombre del producto y variante para display sin JOIN.
  productName    String   @map("product_name")
  colorName      String   @map("color_name")
  sizeLabel      String   @map("size_label")

  @@index([orderId])
  @@map("order_item")
  @@schema("public")
}

// ---------------------------------------------------------------------------
// Carrito (PR #7).
//
// Un `Cart` vive el ciclo completo del cliente: anónimo (cookie firmada con
// HMAC) o asociado a un `Profile`. Al login, el cart anónimo se fusiona con el
// del user (helper `mergeAnonymousCart`).
//
// `CartItem` referencia un `Sku` (no `Variant`) porque el SKU es la unidad
// vendible con precio y stock; la variante es solo la combinación color×talla.
// `@@unique([cartId, skuId])` permite `addToCart` idempotente por SKU.
//
// Precios NO se cachean aquí — se leen de `Sku.price` en /cart y checkout.
// ---------------------------------------------------------------------------

model Cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// null = carrito anónimo (identificado por cookie firmada).
  /// no-null = ligado a un profile (uno por usuario, ver unique parcial en SQL).
  userId    String?    @unique @map("user_id") @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  items     CartItem[]

  @@index([userId])
  @@map("cart")
  @@schema("public")
}

model CartItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  skuId     String   @map("sku_id") @db.Uuid
  sku       Sku      @relation(fields: [skuId], references: [id], onDelete: Restrict)
  /// Cantidad; siempre > 0 (CHECK en supplement). Máx validado en app contra sku.stock.
  qty       Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([cartId, skuId])
  @@index([skuId])
  @@map("cart_item")
  @@schema("public")
}

model ProductImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// Opcional: si está seteado, esta imagen representa la variante de ese color.
  colorId   String?  @map("color_id") @db.Uuid
  color     Color?   @relation(fields: [colorId], references: [id], onDelete: SetNull)
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([productId, url])
  @@index([productId, sortOrder])
  @@index([productId, colorId])
  @@map("product_image")
  @@schema("public")
}
