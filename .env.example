# =============================================================================
# VianStore — variables de entorno
# Copia este archivo a `.env.local` para desarrollo local y llena los valores.
# NUNCA commitees `.env.local` ni ningún archivo con secrets.
# =============================================================================

# --- Next.js -----------------------------------------------------------------
# URL pública de la app (usada en emails y OAuth callbacks).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------------------
# Se llena en PR #2. Obten los valores en tu dashboard de Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma / Postgres -------------------------------------------------------
# Se llena en PR #2. Usa la URL del pooler de Supabase (puerto 6543) para
# `DATABASE_URL` y la URL directa (puerto 5432) para `DIRECT_URL`.
DATABASE_URL=
DIRECT_URL=

# --- Resend (emails transaccionales) -----------------------------------------
# Se llena en PR #9.
RESEND_API_KEY=
EMAIL_FROM="VianStore <no-reply@vianstore.example>"

# --- Runtime -----------------------------------------------------------------
# Zona horaria del server para cálculos de "hoy" y "este mes" en el dashboard.
TZ=America/Bogota
