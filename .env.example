# =============================================================================
# VianStore — variables de entorno
# Copia este archivo a `.env.local` para desarrollo local y llena los valores.
# NUNCA commitees `.env.local` ni ningún archivo con secrets.
# =============================================================================

# --- Next.js -----------------------------------------------------------------
# URL pública de la app (usada en emails y OAuth callbacks).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------------------
# Dashboard → Project Settings → API para URL y keys.
# Supabase 2025 migró del anon JWT (`eyJ...`) al nuevo formato `sb_publishable_*`
# — ambos siguen funcionando. Preferir el nuevo (`_PUBLISHABLE_KEY`); el anon
# queda como fallback opcional por si alguna lib legacy lo pide.
# NUNCA expongas SUPABASE_SERVICE_ROLE_KEY al cliente (browser). Solo server-side.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma / Postgres -------------------------------------------------------
# Dashboard → Project Settings → Database → Connection string.
# DATABASE_URL: pooler PgBouncer transaction mode (puerto 6543). Requiere
#   `?pgbouncer=true&connection_limit=1` para desactivar prepared statements
#   (incompatibles con transaction pooling) y para evitar saturar slots en
#   entornos serverless (Vercel).
# DIRECT_URL: conexión directa a Postgres (puerto 5432). Solo la usan las
#   migraciones (`prisma migrate`), no el runtime.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Seed (dev only) ---------------------------------------------------------
# El script db/seed.ts crea/promueve un admin de prueba. Opcional: sobrescribir
# el email/password por defecto (admin@vianstore.local / vianstore-dev-admin).
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=

# --- Carrito (PR #7) ---------------------------------------------------------
# Secret para firmar la cookie del carrito anónimo (HMAC-SHA256). Debe tener
# >=32 chars random. Genera uno con:
#   node -e "console.log(require('node:crypto').randomBytes(48).toString('base64url'))"
CART_COOKIE_SECRET=

# --- Checkout (PR #8) --------------------------------------------------------
# Costo de envío fijo en centavos. Ejemplo: 1500000 = 15.000 COP. Default 0.
SHIPPING_COST_CENTS=0

# --- Dashboard admin (PR #13) ------------------------------------------------
# Umbral de "stock bajo" — SKUs con stock ≤ este valor aparecen en la lista
# del dashboard. Default 3.
LOW_STOCK_THRESHOLD=3

# --- Storefront público ------------------------------------------------------
# URL base pública del sitio; se usa en metadataBase, sitemap y robots.
# En dev acepta http://localhost:3000 por default; en producción debe apuntar
# al dominio real para no indexar URLs muertas.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Resend (emails transaccionales, PR #9) ----------------------------------
# API key desde https://resend.com/api-keys. Si vacío en dev, los emails no se
# envían — se logean a consola. En producción es requerido.
RESEND_API_KEY=
# Remitente. Debe pertenecer a un dominio verificado en Resend en prod.
EMAIL_FROM="VianStore <no-reply@vianstore.example>"
# Opcional (dev/staging): redirige TODOS los correos a esta dirección. El
# destino original queda en el subject: `[dev:cliente@ejemplo.com] Título`.
# Útil para probar contra Gmail/Outlook reales sin mandarle al cliente.
EMAIL_DEV_REDIRECT_TO=

# --- Emails post-compra (PR #12) ---------------------------------------------
# `1` → dispara email de agradecimiento cuando el admin marca `entregado`.
# Cualquier otro valor (o vacío) → no envía. Útil para evitar spam de correos
# durante calibración inicial del flujo de despacho.
ENABLE_DELIVERY_EMAIL=

# --- Runtime -----------------------------------------------------------------
# Zona horaria del server para cálculos de "hoy" y "este mes" en el dashboard.
TZ=America/Bogota
